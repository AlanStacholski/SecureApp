# ============================================================
# SecureApp — Variáveis de Ambiente
# NUNCA commite o arquivo .env real no repositório
# Copie este arquivo: cp .env.example .env
# ============================================================

# Ambiente (development | production)
ENVIRONMENT=development

# ============================================================
# Banco de dados PostgreSQL
# ============================================================
POSTGRES_DB=secureapp
POSTGRES_USER=secureapp_user
# Use uma senha forte em produção: openssl rand -base64 32
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_AGORA

# ============================================================
# JWT — Autenticação
# ============================================================
# Gere com: openssl rand -hex 32
SECRET_KEY=GERE_UMA_CHAVE_FORTE_COM_OPENSSL

# Access token expira em 15 minutos (segurança: janela curta)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expira em 7 dias
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# Configurações de segurança
# ============================================================
# Origins permitidos no CORS (sem wildcard em produção)
ALLOWED_ORIGINS=http://localhost:3000

# Rate limit: máximo de requisições por minuto por IP
RATE_LIMIT_PER_MINUTE=60
